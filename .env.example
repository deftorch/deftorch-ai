# ============================================================
# REQUIRED — App tidak akan berjalan tanpa variabel ini
# ============================================================

# Auth Secret — generate: openssl rand -base64 32
AUTH_SECRET=

# ============================================================
# GEMINI API KEYS (minimal 1 wajib diisi)
# Auto-rotate: isi sebanyak yang kamu punya untuk distribusi load
# Dapatkan di: https://aistudio.google.com/app/apikey
# ============================================================
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# ... hingga GEMINI_API_KEY_20

# ============================================================
# DATABASE — Vercel Postgres (Neon) direkomendasikan
# WAJIB: pastikan pgvector extension tersedia di instance Postgres Anda
# Vercel Postgres (Neon) sudah mendukung pgvector secara bawaan.
# Dapatkan dari: Vercel Dashboard → Storage → Create Database
# ============================================================
POSTGRES_URL=

# ============================================================
# REDIS — untuk rate limiting
# Opsional: app tetap berjalan tanpa Redis, tapi rate limit tidak aktif
# Dapatkan dari: Vercel Dashboard → Storage → Create KV Store
# ============================================================
REDIS_URL=

# ============================================================
# CLOUDFLARE R2 — untuk penyimpanan file upload
# Dapatkan dari: Cloudflare Dashboard → R2 → Create Bucket
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=

# ============================================================
# OPSIONAL
# ============================================================

# Mode demo (tampilkan /demo sebagai base path)
# IS_DEMO=1
